# Server
PORT=3000
NODE_ENV=production

# Comma-separated allowed frontend origins, example:
# CORS_ORIGINS=https://your-shop.pages.dev,https://your-domain.com
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# JWT secret: use a long random string
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# Admin endpoints require this header: x-admin-secret
ADMIN_SECRET=CHANGE_ME_ADMIN_SECRET

# Firebase Admin SDK
FIREBASE_DATABASE_URL=https://randomshop-a5e9e-default-rtdb.firebaseio.com

# Option A: paste full Firebase service account JSON as one line
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option B: set these instead of JSON
FIREBASE_PROJECT_ID=randomshop-a5e9e
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
