PORT=10000
NODE_ENV=production

# URL frontend cua ban, cach nhau bang dau phay. VD: https://auzastore.ct.ws,https://tenmien.com
CORS_ORIGIN=https://your-frontend-domain.com,http://localhost:5173,http://localhost:3000

# DOI CAI NAY thanh chuoi rat dai
JWT_SECRET=change_this_to_a_very_long_random_secret_64_chars_min

# TK/MK admin nam trong server, khong lo trong web
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password_now

# Firebase Admin SDK
FIREBASE_DATABASE_URL=https://shopnew-d9579-default-rtdb.firebaseio.com
# Cach 1: Base64 JSON service account, khuyen dung cho Render
FIREBASE_SERVICE_ACCOUNT_BASE64=
# Cach 2: duong dan file serviceAccountKey.json neu chay local
GOOGLE_APPLICATION_CREDENTIALS=

# Optional: cho phep user tu dang ky hay khong
ALLOW_REGISTER=true
